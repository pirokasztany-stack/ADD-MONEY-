    header.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    header.Parent = main
    Instance.new("UICorner", header)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0.6, 0)
    title.Text = "LUMA MULTI-HACK"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 20 -- POWIĘKSZONE
    title.BackgroundTransparency = 1
    title.Parent = header

    local subTitle = Instance.new("TextLabel")
    subTitle.Size = UDim2.new(1, 0, 0.4, 0)
    subTitle.Position = UDim2.new(0, 0, 0.55, 0)
    subTitle.Text = "ADVANCED GAME HACK"
    subTitle.TextColor3 = Color3.fromRGB(0, 255, 150)
    subTitle.Font = Enum.Font.Gotham
    subTitle.TextSize = 13 -- POWIĘKSZONE
    subTitle.BackgroundTransparency = 1
    subTitle.Parent = header

    -- PRZYCISK ZAMKNIĘCIA (X)
