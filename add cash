-- [[ LUMA MULTI-HACK V4 - ACCESSIBILITY UPDATE ]] --

local UIS = game:GetService("UserInputService")
local RS = game:GetService("ReplicatedStorage")
local TS = game:GetService("TweenService")
local Player = game.Players.LocalPlayer

local sg = Instance.new("ScreenGui")
sg.Name = "Luma_Multi_V4"
sg.Parent = game.CoreGui

-- --- SYSTEM DŹWIĘKÓW ---
local function playSfx(id)
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://" .. tostring(id)
    s.Volume = 0.6
    s.Parent = game.SoundService
    s:Play()
    s.Ended:Connect(function() s:Destroy() end)
end

-- --- UI: PASEK STATUSU ---
local statusFrame = Instance.new("Frame")
statusFrame.Size = UDim2.new(0, 400, 0, 60)
statusFrame.Position = UDim2.new(0.5, -200, 1, 100)
statusFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
statusFrame.Parent = sg
Instance.new("UICorner", statusFrame).CornerRadius = UDim.new(0, 12)

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, 0, 1, 0)
statusLabel.BackgroundTransparency = 1
statusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
statusLabel.Font = Enum.Font.Code
statusLabel.TextSize = 18 -- POWIĘKSZONE
statusLabel.Text = "LUMA: INITIALIZING DEEP SCAN..."
statusLabel.Parent = statusFrame

-- --- LOGIKA SKANOWANIA ---
local foundStats = {} 

local function runDeepScan()
    TS:Create(statusFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -200, 1, -80)}):Play()
    task.wait(1)

    local statsFolder = Player:FindFirstChild("leaderstats")
    if not statsFolder then
        statusLabel.Text = "ERROR: NO LEADERSTATS"
        playSfx(139063727738556)
        task.wait(2)
        sg:Destroy()
        return
    end

    local allRemotes = RS:GetDescendants()
    for _, stat in pairs(statsFolder:GetChildren()) do
        if stat:IsA("IntValue") or stat:IsA("NumberValue") then
            statusLabel.Text = "SCANNING: " .. stat.Name:upper()
            for _, r in pairs(allRemotes) do
                if (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
                    local rn = r.Name:lower()
                    local sn = stat.Name:lower()
                    if rn:find(sn) or (sn == "money" and rn:find("cash")) or (sn == "rebirths" and rn:find("reb")) then
                        table.insert(foundStats, {Obj = stat, Remote = r, Name = stat.Name})
                        break
                    end
                end
            end
        end
    end

    if #foundStats > 0 then
        statusLabel.Text = "VERIFICATION SUCCESSFUL!"
        playSfx(117748447860239)
        task.wait(1.5)
        TS:Create(statusFrame, TweenInfo.new(0.5), {Position = UDim2.new(0.5, -200, 1, 100)}):Play()
        task.wait(0.6)
        statusFrame:Destroy()
        createMainGui()
    else
        statusLabel.Text = "VULNERABILITY NOT FOUND"
        playSfx(139063727738556)
        task.wait(2)
        sg:Destroy()
    end
end

-- --- GŁÓWNE GUI ---
function createMainGui()
    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, 280, 0, 320)
    main.Position = UDim2.new(0.5, -140, 0.5, -160)
    main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
