    -- --- PODPIS MADE BY LUMA GUI ---
    local signature = Instance.new("TextLabel")
    signature.Size = UDim2.new(1, 0, 0, 20)
    signature.Position = UDim2.new(0, 0, 1, -25) -- Na samym dole
    signature.Text = "MADE BY LUMA GUI"
    signature.TextColor3 = Color3.fromRGB(120, 120, 120) -- Subtelny szary
    signature.Font = Enum.Font.Gotham
    signature.TextSize = 11
    signature.BackgroundTransparency = 1
    signature.Parent = main

    -- Akcja przycisku z animacją koloru
    btn.MouseButton1Click:Connect(function()
        local val = tonumber(amountInput.Text)
        if val and foundRemote then
            foundRemote:FireServer(val)
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            btn.Text = "SUCCESS!"
            task.wait(0.5)
            btn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
            btn.Text = "ADD VALUE"
        end
    end)

    -- Przycisk X (Zamknij)
    local close = Instance.new("TextButton")
