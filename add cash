-- [[ VALUE HACK V1 - LUMA GUI ]] --

local UIS = game:GetService("UserInputService")
local RS = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Player = game.Players.LocalPlayer

task.wait(1)

local sg = Instance.new("ScreenGui")
sg.Name = "LumaValueHack"
sg.Parent = game.CoreGui

-- --- NOWOCZESNY PASEK ŁADOWANIA ---
local loadFrame = Instance.new("Frame")
loadFrame.Size = UDim2.new(0, 350, 0, 50)
loadFrame.Position = UDim2.new(0.5, -175, 1, -80)
loadFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
loadFrame.BorderSizePixel = 0
loadFrame.Parent = sg

local uiCornerLoad = Instance.new("UICorner")
uiCornerLoad.CornerRadius = UDim.new(0, 12)
uiCornerLoad.Parent = loadFrame

local loadLabel = Instance.new("TextLabel")
loadLabel.Size = UDim2.new(1, 0, 1, 0)
loadLabel.BackgroundTransparency = 1
loadLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
loadLabel.Font = Enum.Font.Code
loadLabel.TextSize = 15
loadLabel.Text = "SYSTEM BOOTING..."
loadLabel.Parent = loadFrame

local foundRemote = nil
local moneyKeywords = {"cash", "coin", "money", "currency", "gold", "add", "egg", "neko"}

-- --- SZUKANIE LEADERSTATÓW ---
local function getMyMoneyValue()
    local stats = Player:FindFirstChild("leaderstats")
    if stats then
        for _, v in pairs(stats:GetChildren()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") or v:IsA("StringValue") then
                return v
            end
        end
    end
    return nil
end

local function runLoading()
    loadLabel.Text = "Searching for Player Leaderstats..."
    task.wait(0.8)
    
    local myValueObj = getMyMoneyValue()
    
    if not myValueObj then
        loadLabel.Text = "CRITICAL ERROR: NO STATS FOUND"
        loadLabel.TextColor3 = Color3.new(1, 0, 0)
        task.wait(2)
        sg:Destroy()
        return
    end

    loadLabel.Text = "Intercepting RemoteEvents..."
    local potentials = {}
    for _, v in pairs(RS:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            local n = v.Name:lower()
            for _, key in pairs(moneyKeywords) do
                if n:find(key) then table.insert(potentials, v) break end
            end
        end
    end

    -- TESTOWANIE +1
    local success = false
    for _, remote in pairs(potentials) do
        loadLabel.Text = "Testing: " .. remote.Name
        local old = tonumber(myValueObj.Value) or 0
        remote:FireServer(1)
        
        task.wait(0.6)
        
        local new = tonumber(myValueObj.Value) or 0
        if new > old then
            foundRemote = remote
            success = true
            break
        end
    end

    if success then
        loadLabel.Text = "CONNECTED TO: " .. foundRemote.Name:upper()
        loadLabel.TextColor3 = Color3.new(0, 1, 0)
        task.wait(1)
        loadFrame:Destroy()
        createMainGui()
    else
        loadLabel.Text = "VULNERABILITY TEST FAILED"
        loadLabel.TextColor3 = Color3.new(1, 0, 0)
        task.wait(2)
        sg:Destroy()
    end
end

-- --- GŁÓWNE GUI (Z PODPISEM LUMA) ---
