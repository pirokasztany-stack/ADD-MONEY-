    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 18
    closeBtn.Parent = main
    Instance.new("UICorner", closeBtn)
    closeBtn.MouseButton1Click:Connect(function() sg:Destroy() end)

    -- DROPDOWN LISTA
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(0.9, 0, 0, 90)
    scroll.Position = UDim2.new(0.05, 0, 0.22, 0)
    scroll.BackgroundTransparency = 1
    scroll.CanvasSize = UDim2.new(0, 0, 2, 0)
    scroll.ScrollBarThickness = 3
    scroll.Parent = main

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 6)
    layout.Parent = scroll

    local selectedData = foundStats[1]

    for _, data in pairs(foundStats) do
        local opt = Instance.new("TextButton")
        opt.Size = UDim2.new(1, -10, 0, 30)
        opt.Text = "Target: " .. data.Name
        opt.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        opt.TextColor3 = Color3.new(0.8, 0.8, 0.8)
        opt.Font = Enum.Font.Gotham
        opt.TextSize = 14
        opt.Parent = scroll
        Instance.new("UICorner", opt)

        opt.MouseButton1Click:Connect(function()
            playSfx(133915937837646)
            selectedData = data
            for _, b in pairs(scroll:GetChildren()) do if b:IsA("TextButton") then b.TextColor3 = Color3.new(0.8, 0.8, 0.8) end end
            opt.TextColor3 = Color3.fromRGB(0, 255, 150)
        end)
    end

    -- INPUT: AMOUNT
    local amountInput = Instance.new("TextBox")
    amountInput.Size = UDim2.new(0.8, 0, 0, 40)
    amountInput.Position = UDim2.new(0.1, 0, 0.55, 0)
    amountInput.PlaceholderText = "Amount" -- Zmienione z TextBox na Amount
    amountInput.Text = "" -- Czyścimy domyślny tekst
    amountInput.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    amountInput.TextColor3 = Color3.new(1, 1, 1)
    amountInput.Font = Enum.Font.Gotham
    amountInput.TextSize = 16
    amountInput.Parent = main
    Instance.new("UICorner", amountInput)

    -- BUTTON: INJECT
    local addBtn = Instance.new("TextButton")
    addBtn.Size = UDim2.new(0.8, 0, 0, 50)
    addBtn.Position = UDim2.new(0.1, 0, 0.72, 0)
    addBtn.Text = "INJECT VALUE"
    addBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    addBtn.TextColor3 = Color3.new(1, 1, 1)
    addBtn.Font = Enum.Font.GothamBold
    addBtn.TextSize = 18
    addBtn.Parent = main
    Instance.new("UICorner", addBtn)

    addBtn.MouseButton1Click:Connect(function()
        if selectedData and selectedData.Remote then
            playSfx(133915937837646)
            playSfx(139922061047157)
            local val = tonumber(amountInput.Text) or 0
            if selectedData.Remote:IsA("RemoteEvent") then selectedData.Remote:FireServer(val) else selectedData.Remote:InvokeServer(val) end
            
            addBtn.Text = "SUCCESS!"
            task.wait(1)
            addBtn.Text = "INJECT VALUE"
        end
    end)

    local sig = Instance.new("TextLabel")
    sig.Size = UDim2.new(1, 0, 0, 25)
    sig.Position = UDim2.new(0, 0, 1, -30)
    sig.Text = "MADE BY LUMA GUI"
    sig.TextColor3 = Color3.fromRGB(150, 150, 150)
    sig.TextSize = 12
    sig.BackgroundTransparency = 1
    sig.Parent = main
    
    main.Active = true
    main.Draggable = true
end

task.spawn(runDeepScan)
